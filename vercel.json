{
  "version": 2,

  "builds": [
    {
      "src": "backend/src/app.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**/*",
      "use": "@vercel/static"
    }
  ],

  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/src/app.js"
    },

    {
      "src": "/",
      "status": 302,
      "headers": {
        "Location": "/frontend/login/login.html"
      }
    },

    {
      "src": "/loja/(.*)",
      "dest": "/frontend/public/loja/index.html"
    },

    {
      "src": "/cliente",
      "status": 302,
      "headers": {
        "Location": "/frontend/public/index.html"
      }
    },

    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ]
}
