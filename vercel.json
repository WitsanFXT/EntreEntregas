{
  "version": 2,
  "builds": [
    {
      "src": "backend/src/app.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/src/app.js"
    },
    {
      "src": "/",
      "status": 302,
      "headers": {
        "Location": "/frontend/login/login.html"
      }
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ]
}
